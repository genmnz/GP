# Where trained weights live (gitignored). Missing weights -> deterministic stub mode.
MODEL_DIR=models

# Image preprocessing size and audio sample rate.
IMG_SIZE=224
SAMPLE_RATE=16000

# Decision threshold for the binary classifiers (accident / ambulance / siren).
BINARY_THRESHOLD=0.5

# --- Live streaming (/stream, the web /live page). Needs the [stream] extra. ---
# Allowed CORS origin(s) for the dashboard's EventSource (comma-separated, or *).
CORS_ORIGIN=http://localhost:3001
# Vehicle-count -> congestion-label cutoffs (empty<=a<low<=b<high<=c<jam).
# Calibrate on your data with the v2 notebook (Track B) and paste the result here.
COUNT_THRESHOLDS=3,8,15
# YOLO detector weights for the live vehicle count (auto-downloads if absent).
YOLO_MODEL=yolo11n.pt

LOG_LEVEL=INFO
