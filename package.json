{
	"name": "ziko",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"typescript": "^6",
			"@types/bun": "^1.3.4",
			"lucide-react": "^1.21.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.7",
			"react-dom": "^19.2.7",
			"sonner": "^2.0.7",
			"@types/react": "^19.2.17",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.3.1"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"check-types": "turbo run check-types",
		"dev:web": "turbo run dev -F web",
		"dev:server": "turbo run dev -F server",
		"db:studio": "turbo run db:studio -F @ziko/db",
		"db:generate": "turbo run db:generate -F @ziko/db",
		"db:migrate": "turbo run db:migrate -F @ziko/db",
		"check": "biome check --write .",
		"test": "turbo run test && bun run test:ml",
		"test:ml": "cd services/ml && python -m pytest"
	},
	"dependencies": {
		"@ziko/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@types/bun": "catalog:",
		"@ziko/config": "workspace:*",
		"turbo": "^2.9.16",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.14"
}
